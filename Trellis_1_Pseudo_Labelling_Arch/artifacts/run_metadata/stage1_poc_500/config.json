{
    "models": {
        "denoiser": {
            "name": "SparseStructureFlowModel",
            "args": {
                "resolution": 16,
                "in_channels": 8,
                "out_channels": 8,
                "model_channels": 1024,
                "cond_channels": 1024,
                "num_blocks": 24,
                "num_heads": 16,
                "mlp_ratio": 4,
                "patch_size": 1,
                "pe_mode": "ape",
                "qk_rms_norm": true,
                "use_fp16": true
            }
        },
        "text_proj": {
            "name": "TextImageConditionProjector",
            "args": {
                "in_channels": 768,
                "out_channels": 1024
            }
        }
    },
    "dataset": {
        "name": "Arch1ConditionedSparseStructureLatent",
        "args": {}
    },
    "trainer": {
        "name": "Arch1ConditionedFlowMatchingCFGTrainer",
        "args": {
            "max_steps": 500,
            "batch_size_per_gpu": 2,
            "batch_split": 1,
            "optimizer": {
                "name": "AdamW",
                "args": {
                    "lr": 0.0001,
                    "weight_decay": 0.0
                }
            },
            "ema_rate": [
                0.9999
            ],
            "fp16_mode": "inflat_all",
            "fp16_scale_growth": 0.001,
            "grad_clip": {
                "name": "AdaptiveGradClipper",
                "args": {
                    "max_norm": 1.0,
                    "clip_percentile": 95
                }
            },
            "i_log": 10,
            "i_sample": 1000000,
            "i_save": 250,
            "p_uncond": 0.1,
            "t_schedule": {
                "name": "logitNormal",
                "args": {
                    "mean": 1.0,
                    "std": 1.0
                }
            },
            "sigma_min": 1e-05
        }
    }
}